# ── Databases ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://trading:trading_dev@localhost:5432/trading

QUESTDB_HOST=localhost
QUESTDB_PG_PORT=8812
QUESTDB_HTTP_PORT=9000

REDIS_URL=redis://localhost:6379/0

# ── Security ─────────────────────────────────────────────────────────────────
# Generate a Fernet key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=REPLACE_WITH_GENERATED_FERNET_KEY

# JWT secret for dashboard auth (any long random string)
JWT_SECRET=REPLACE_WITH_RANDOM_SECRET

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Set LLM_PROVIDER to: openai | gemini | anthropic
LLM_PROVIDER=openai
LLM_CONFIDENCE_THRESHOLD=0.70

OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ── MetaTrader 5 (Windows only) ───────────────────────────────────────────────
# Path to terminal64.exe — leave empty to use default MT5 installation
MT5_PATH=

# ── Application ──────────────────────────────────────────────────────────────
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# ── Trading Safety ────────────────────────────────────────────────────────────
MAX_DRAWDOWN_PERCENT=10.0    # Kill switch triggers above this drawdown %
MAX_OPEN_POSITIONS=5         # Per account
DEFAULT_RISK_PERCENT=1.0     # % of balance risked per trade
